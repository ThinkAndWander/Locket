{
	"compilerOptions": {
		"rootDir": "./",
		"outDir": "./build",
		"target": "es6",
		"moduleResolution": "node",
		"sourceMap": true,
		"removeComments": true,
		"noImplicitAny": true,
		"noImplicitThis": true,
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"strictBindCallApply": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		// Please do not add "no unused vars" because that requires commenting out code to get around it while testing
		// mid-change and can result in leaving comments in committed code.
		"lib": [
			"DOM",
			"ES5",
			"ES2015",
			"ES2016",
			"ES2017",
			"ES2018",
			"ES2019",
			"ES2020",
			"ES2021",
			"ES2022",
			"ESNext"
		],
	}
}